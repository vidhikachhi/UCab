# Backend Environment Variables - EXAMPLE FILE
# Copy this to .env and fill in the values

# Server Port
PORT=5000

# MongoDB Connection URI
# For Local MongoDB:
# MONGO_URI=mongodb://localhost:27017/swiftcab

# For MongoDB Atlas (Cloud):
# MONGO_URI=mongodb+srv://admin:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/swiftcab?retryWrites=true&w=majority

MONGO_URI=mongodb://localhost:27017/swiftcab

# Node Environment
NODE_ENV=development
